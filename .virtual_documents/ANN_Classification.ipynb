import pandas as pd
import numpy as np


df = pd.read_csv("powerplant_data.csv")


df.head()


df.isnull().sum()


# AT - Temperature
# V - Vaccum
# AP - Pressure
# RH - Humidity

# PE - Produced Energy


X = df.drop("PE", axis=1)
y = df["PE"]


# SPlit our data
from sklearn.model_selection import train_test_split

X_train, X_test, y_train, y_test = train_test_split(
    X, y,test_size=0.20, random_state = 42
)


from sklearn.preprocessing import StandardScaler

scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)


# converting data into tensors

import torch
import torch.nn as nn

X_train_tensor = torch.tensor(X_train_scaled, dtype=torch.float32)
y_train_tensor = torch.tensor(y_train.values, dtype=torch.float32).view(-1,1)

X_test_tensor = torch.tensor(X_test_scaled, dtype=torch.float32)
y_test_tensor = torch.tensor(y_test.values, dtype=torch.float32).view(-1,1)


type(X_train_scaled)


type(y_train)


from torch.utils.data import TensorDataset, DataLoader

train_dataset = TensorDataset(X_train_tensor, y_train_tensor)
test_dataset = TensorDataset(X_test_tensor,y_test_tensor)

train_loader = DataLoader(train_dataset, batch_size = 32, shuffle=True)
test_loader = DataLoader(test_dataset, batch_size = 32)





# Building our ANN model

class ANN(nn.Module):
    def __init__(self):

        #calling parent class(nn.Module) constructor
        super(ANN,self).__init__()

        self.model = nn.Sequential(
            #1st hidden layer
            nn.Linear(X_train.shape[1],6),
            nn.ReLU(),

            #2nd Hidden Layer
            nn.Linear(6,6),
            nn.ReLU(),

            #o/p layer
            nn.Linear(6,1),
        )

    def forward(self,x):
        return self.model(x)


# X_train.shape -- tuple -- 0 idx : samples, 1 idx : i/p features


import torch.optim as optim
model = ANN()

#lass & optimizers
criterion = nn.MSELoss()
optimizer = optim.Adam(model.parameters())


# Training the ANN

epochs = 100
train_loss = []

for epoch in range(epochs):
    model.train()

    # To calculate loss for each epoch
    running_loss = 0.0
    
    for xb,yb in train_loader:

        #xb - features of each batch
        #yb - labels of each batch

        # Zero_grad()--helps us no to accumalates grads of previous batch
        optimizer.zero_grad()

        # Forward propagation.. predicted o/p's for each batch
        outputs = model(xb)

        # Will compute loss
        loss = criterion(outputs,yb)

        # Backward Propagation.. compute gradients
        loss.backward()

        # will update params
        optimizer.step()

        # loss is a tensor value, loss.item() will convert to python
        running_loss += loss.item()

